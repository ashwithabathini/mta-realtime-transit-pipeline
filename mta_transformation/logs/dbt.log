[0m03:21:33.218836 [debug] [Thread-1 (]: On model.mta_transformation.mta_arrival_status: /* {"app": "dbt", "dbt_version": "1.11.6", "profile_name": "mta_transformation", "target_name": "dev", "node_id": "model.mta_transformation.mta_arrival_status"} */

  
    

    create or replace table `mta-transit-project-488901`.`mta_data`.`mta_arrival_status`
      
    
    

    
    OPTIONS()
    as (
      

WITH raw_data AS (
    SELECT 
        trip_id,
        route_id,
        -- Cleans stop_id to ensure the JOIN with static_stops works
        REGEXP_REPLACE(stop_id, r'[NS]$', '') as clean_stop_id,
        arrival_timestamp,
        CAST(ingested_at AS INT64) as ingested_at_unix,
        -- Display times for dashboard reference in NYC time
        DATETIME(TIMESTAMP_SECONDS(arrival_timestamp), "America/New_York") as arrival_time,
        DATETIME(TIMESTAMP_SECONDS(CAST(ingested_at AS INT64)), "America/New_York") as ingested_at
    FROM `mta-transit-project-488901`.`mta_data`.`raw_trip_updates`
),

joined_data AS (
    SELECT 
        r.*,
        s.stop_name
    FROM raw_data r
    LEFT JOIN `mta-transit-project-488901`.`mta_data`.`static_stops` s ON r.clean_stop_id = s.stop_id
)

SELECT 
    * EXCEPT(arrival_timestamp, ingested_at_unix, clean_stop_id),
    CASE 
        -- ON TIME: Arriving within 1 min early or 5 mins late
        WHEN (arrival_timestamp - ingested_at_unix) BETWEEN -60 AND 300 THEN 'On Time'
        -- DELAYED: More than 5 mins past the predicted arrival
        WHEN (arrival_timestamp - ingested_at_unix) < -60 THEN 'Delayed'
        -- FUTURE: Predictions for stops more than 5 mins away
        ELSE 'Future'
    END as trip_status
FROM joined_data
    );
  
