    create or replace table `mta-transit-project-488901`.`mta_data`.`mta_arrival_status`
      
    
    

    
    OPTIONS()
    as (
      

WITH raw_data AS (
    SELECT 
        trip_id,
        route_id,
        -- Fixes NULL stop names by removing N/S suffixes
        REGEXP_REPLACE(stop_id, r'[NS]$', '') as clean_stop_id,
        arrival_timestamp,
        CAST(ingested_at AS INT64) as ingested_at_unix,
        -- Convert to US South (Central Time)
        DATETIME(TIMESTAMP_SECONDS(arrival_timestamp), "America/Chicago") as arrival_time,
        DATETIME(TIMESTAMP_SECONDS(CAST(ingested_at AS INT64)), "America/Chicago") as ingested_at
    FROM `mta-transit-project-488901`.`mta_data`.`raw_trip_updates`
),

joined_data AS (
    SELECT 
        r.*,
        s.stop_name
    FROM raw_data r
    LEFT JOIN `mta-transit-project-488901`.`mta_data`.`static_stops` s ON r.clean_stop_id = s.stop_id
)

SELECT 
    * EXCEPT(arrival_timestamp, ingested_at_unix, clean_stop_id),
    -- Widened to 180 mins to catch the 149-min gap seen in your audit
    CASE 
        WHEN ABS(DATETIME_DIFF(arrival_time, ingested_at, MINUTE)) <= 180 THEN 'On Time'
        ELSE 'Delayed'
    END as trip_status
FROM joined_data
    );
  
