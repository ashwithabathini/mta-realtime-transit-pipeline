[0m03:43:41.331783 [debug] [Thread-1 (]: On model.mta_transformation.mta_arrival_status: /* {"app": "dbt", "dbt_version": "1.11.6", "profile_name": "mta_transformation", "target_name": "dev", "node_id": "model.mta_transformation.mta_arrival_status"} */

  
    

    create or replace table `mta-transit-project-488901`.`mta_data`.`mta_arrival_status`
      
    
    

    
    OPTIONS()
    as (
      

WITH raw_updates AS (
    SELECT 
        -- This logic strips the 'N' or 'S' from the end of the ID
        CASE 
            WHEN stop_id LIKE '%N' OR stop_id LIKE '%S' 
            THEN LEFT(stop_id, LENGTH(stop_id) - 1)
            ELSE stop_id 
        END AS clean_stop_id,
        arrival_time,
        trip_id,
        route_id
    FROM `mta-transit-project-488901`.`mta_data`.`raw_trip_updates`
),

stops_info AS (
    SELECT 
        stop_id,
        stop_name,
        stop_lat,
        stop_lon
    FROM `mta-transit-project-488901`.`mta_data`.`static_stops`
)

SELECT 
    r.trip_id,
    r.route_id,
    s.stop_name,
    r.arrival_time,
    s.stop_lat,
    s.stop_lon
FROM raw_updates r
LEFT JOIN stops_info s ON r.clean_stop_id = s.stop_id
    );
  
