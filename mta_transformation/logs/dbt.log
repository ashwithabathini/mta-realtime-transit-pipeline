    create or replace table `mta-transit-project-488901`.`mta_data`.`mta_arrival_status`
      
    
    

    
    OPTIONS()
    as (
      

WITH raw_data AS (
    SELECT 
        trip_id,
        route_id,
        stop_id,
        arrival_timestamp,
        CAST(ingested_at AS INT64) as ingested_at_unix,
        DATETIME(TIMESTAMP_SECONDS(arrival_timestamp), "America/New_York") as arrival_time,
        DATETIME(TIMESTAMP_SECONDS(CAST(ingested_at AS INT64)), "America/New_York") as ingested_at
    FROM `mta-transit-project-488901`.`mta_data`.`raw_trip_updates`
),

joined_data AS (
    SELECT 
        r.*,
        s.stop_name
    FROM raw_data r
    LEFT JOIN `mta-transit-project-488901`.`mta_data`.`static_stops` s ON r.stop_id = s.stop_id
)

SELECT 
    * EXCEPT(arrival_timestamp, ingested_at_unix),
    CASE 
        WHEN (arrival_timestamp - ingested_at_unix) BETWEEN -120 AND 900 THEN 'On Time'
        ELSE 'Delayed'
    END as trip_status
FROM joined_data
    );
  
