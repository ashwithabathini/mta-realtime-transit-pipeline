    create or replace table `mta-transit-project-488901`.`mta_data`.`mta_arrival_status`
      
    
    

    
    OPTIONS()
    as (
      

WITH raw_data AS (
    SELECT 
        trip_id,
        route_id,
        stop_id,
        TIMESTAMP_SECONDS(arrival_timestamp) as arrival_time,
        TIMESTAMP_SECONDS(CAST(ingested_at AS INT64)) as ingested_at
    FROM `mta-transit-project-488901`.`mta_data`.`raw_trip_updates`
),

joined_data AS (
    SELECT 
        r.*,
        s.stop_name
    FROM raw_data r
    LEFT JOIN `mta-transit-project-488901`.`mta_data`.`static_stops` s ON r.stop_id = s.stop_id
)

SELECT 
    *,
    -- If arrival is more than 5 mins after we ingested the data, we label it
    CASE 
        WHEN DATETIME_DIFF(arrival_time, ingested_at, MINUTE) > 5 THEN 'Delayed'
        ELSE 'On Time'
    END as trip_status
FROM joined_data
    );
  
